---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const translations = await getCollection('translations');
  return translations.map((translation) => ({
    params: { slug: translation.slug },
    props: { translation },
  }));
}

interface Props {
  translation: CollectionEntry<'translations'>;
}

const { translation } = Astro.props;
const { Content } = await translation.render();
const { chapter, chineseTitle, englishTitle, version, lastUpdated, rsmVersion, confidence, confidenceNotes, changes } = translation.data;

const confidenceColors: Record<string, string> = {
  locked: 'var(--color-locked, #22c55e)',
  strong: 'var(--color-strong, #3b82f6)',
  plausible: 'var(--color-plausible, #eab308)',
  speculative: 'var(--color-speculative, #ef4444)',
};

// Get all translations for prev/next navigation
const allTranslations = await getCollection('translations');
const sorted = allTranslations.sort((a, b) => a.data.chapter - b.data.chapter);
const currentIndex = sorted.findIndex(t => t.data.chapter === chapter);
const prev = currentIndex > 0 ? sorted[currentIndex - 1] : null;
const next = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;
---

<BaseLayout title={`Chapter ${chapter}: ${englishTitle}`}>
  <article class="max-w-2xl mx-auto">
    <!-- Header -->
    <header class="text-center mb-12">
      <p class="themed-text-muted mb-2">道德經 第{chapter}章</p>
      <h1 class="text-4xl font-bold mb-2">{chineseTitle}</h1>
      <p class="text-xl themed-text-secondary mb-4">{englishTitle}</p>
      <div class="flex items-center justify-center gap-4 text-sm themed-text-muted">
        <span>v{version}</span>
        <span>•</span>
        <span>{lastUpdated}</span>
        {rsmVersion && (
          <>
            <span>•</span>
            <span>RSM {rsmVersion}</span>
          </>
        )}
        {confidence && (
          <>
            <span>•</span>
            <span style={`color: ${confidenceColors[confidence]}`}>{confidence}</span>
          </>
        )}
      </div>
    </header>

    <!-- Translation Content -->
    <div class="prose prose-themed prose-lg max-w-none">
      <Content />
    </div>

    <!-- Confidence Notes -->
    {confidenceNotes && confidenceNotes.length > 0 && (
      <section class="mt-12 pt-8 themed-border border-t">
        <h2 class="text-lg font-bold mb-4">Confidence Assessment</h2>
        <div class="space-y-3 text-sm">
          {confidenceNotes.map((cn) => (
            <div class="themed-surface border rounded p-3">
              <div class="flex justify-between mb-1">
                <span class="font-medium">{cn.element}</span>
                <span style={`color: ${confidenceColors[cn.level]}`}>{cn.level}</span>
              </div>
              <p class="themed-text-secondary">{cn.note}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Version History -->
    {changes.length > 0 && (
      <section class="mt-12 pt-8 themed-border border-t">
        <h2 class="text-lg font-bold mb-4">Version History</h2>
        <div class="space-y-3 text-sm">
          {changes.map((change) => (
            <div class="themed-surface border rounded p-3">
              <div class="flex justify-between mb-1">
                <span class="font-medium">v{change.version}</span>
                <span class="themed-text-muted">{change.date}</span>
              </div>
              <p class="themed-text-secondary">{change.notes}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Navigation -->
    <nav class="mt-12 pt-8 themed-border border-t flex justify-between items-center">
      {prev ? (
        <a href={`/ddj/${prev.slug}`} class="themed-text-muted hover:opacity-80 transition-opacity">
          ← Ch. {prev.data.chapter}
        </a>
      ) : (
        <span></span>
      )}
      <a href="/ddj" class="themed-text-muted hover:opacity-80 transition-opacity">
        All Chapters
      </a>
      {next ? (
        <a href={`/ddj/${next.slug}`} class="themed-text-muted hover:opacity-80 transition-opacity">
          Ch. {next.data.chapter} →
        </a>
      ) : (
        <span></span>
      )}
    </nav>
  </article>
</BaseLayout>

<style>
  .prose h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 3rem;
    margin-bottom: 1rem;
    color: var(--color-accent);
  }
  .prose h3 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }
  .prose p {
    margin-bottom: 1rem;
    line-height: 1.8;
    color: var(--color-text-secondary);
  }
  .prose strong {
    font-weight: 700;
    color: var(--color-text);
  }
  .prose blockquote {
    border-left: 4px solid var(--color-accent);
    padding-left: 1.5rem;
    margin: 1.5rem 0;
    color: var(--color-text-secondary);
  }
  .prose ul {
    list-style-type: disc;
    margin-bottom: 1.5rem;
    margin-left: 1.5rem;
    padding-left: 0.5rem;
    color: var(--color-text-secondary);
  }
  .prose ol {
    list-style-type: decimal;
    margin-bottom: 1.5rem;
    margin-left: 1.5rem;
    padding-left: 0.5rem;
    color: var(--color-text-secondary);
  }
  .prose li {
    margin-bottom: 0.5rem;
    padding-left: 0.25rem;
  }
  .prose table {
    width: 100%;
    margin: 1.5rem 0;
    border-collapse: collapse;
    font-size: 0.95rem;
  }
  .prose th {
    text-align: left;
    padding: 0.75rem 1rem;
    border-bottom: 2px solid var(--color-border);
    color: var(--color-text);
    font-weight: 600;
    background: var(--color-surface);
  }
  .prose td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-border-light);
    color: var(--color-text-secondary);
    vertical-align: top;
  }
  .prose code {
    background: var(--color-surface);
    padding: 0.2rem 0.5rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
    border: 1px solid var(--color-border-light);
  }
  .prose pre {
    background: var(--color-surface);
    padding: 1.25rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin: 1.5rem 0;
    border: 1px solid var(--color-border);
    font-size: 0.9rem;
    line-height: 1.6;
  }
  .prose pre code {
    background: transparent;
    padding: 0;
    border: none;
  }
  .prose hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0;
  }
</style>
