---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Our Infinite Reality">
  <div class="max-w-3xl mx-auto">

    <!-- Generous whitespace -->
    <div class="pt-16 md:pt-24"></div>

    <!-- Three contemplation icons -->
    <div class="landing-icons">
      <button class="landing-icon-wrapper" data-contemplation="bundle" aria-label="The Bundle">
        <svg viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="36" cy="36" r="28" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
          <circle cx="36" cy="36" r="20" stroke="currentColor" stroke-width="1.5" opacity="0.5"/>
          <circle cx="36" cy="36" r="12" stroke="currentColor" stroke-width="1.5" opacity="0.7"/>
          <line x1="36" y1="6" x2="36" y2="66" stroke="currentColor" stroke-width="1.5" opacity="0.9"/>
        </svg>
      </button>

      <button class="landing-icon-wrapper" data-contemplation="wind" aria-label="The Wind">
        <svg viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="32" y="30" width="8" height="28" rx="2" stroke="currentColor" stroke-width="1.5" opacity="0.7"/>
          <path d="M30 30 Q36 22 42 30" stroke="currentColor" stroke-width="1.5" fill="none" opacity="0.4"/>
          <path d="M28 24 Q36 14 44 24" stroke="currentColor" stroke-width="1.5" fill="none" opacity="0.3"/>
          <path d="M26 18 Q36 6 46 18" stroke="currentColor" stroke-width="1.5" fill="none" opacity="0.2"/>
        </svg>
      </button>

      <button class="landing-icon-wrapper" data-contemplation="toss" aria-label="The Toss">
        <svg viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg">
          <line x1="12" y1="58" x2="60" y2="58" stroke="currentColor" stroke-width="1.5" opacity="0.5"/>
          <circle cx="20" cy="52" r="3" fill="currentColor" opacity="0.8"/>
          <circle cx="36" cy="48" r="3.5" fill="currentColor" opacity="0.9"/>
          <circle cx="52" cy="50" r="3" fill="currentColor" opacity="0.85"/>
          <circle cx="28" cy="38" r="2.5" fill="currentColor" opacity="0.5"/>
          <circle cx="44" cy="34" r="2" fill="currentColor" opacity="0.4"/>
          <circle cx="34" cy="22" r="1.5" fill="currentColor" opacity="0.25"/>
          <circle cx="50" cy="18" r="1.5" fill="currentColor" opacity="0.2"/>
        </svg>
      </button>
    </div>

    <!-- Bridge line -->
    <div class="pt-16 md:pt-24"></div>
    <p class="text-center themed-text-secondary leading-relaxed italic max-w-lg mx-auto">
      If any of these connected to each other — if the cut, the wind, and the toss felt like three angles on the same thing — you're ready for what's here.
    </p>

    <div class="themed-border border-t my-12"></div>

    <!-- Content navigation -->
    <section class="mb-12">

      <!-- Start here -->
      <div class="mb-8">
        <h3 class="text-lg font-bold mb-4 themed-text-muted">Start here</h3>
        <div class="space-y-3">
          <a href="/overview" class="block themed-surface border rounded-lg p-4 transition-colors hover:opacity-80">
            <p class="font-semibold">Overview</p>
            <p class="text-sm themed-text-muted">The pattern, the project, the invitation.</p>
          </a>
          <a href="/text/what-is-ddj" class="block themed-surface border rounded-lg p-4 transition-colors hover:opacity-80">
            <p class="font-semibold">What Is the Dao De Jing?</p>
            <p class="text-sm themed-text-muted">For people who've never heard of it.</p>
          </a>
          <a href="/ddj/chapter-01" class="block themed-surface border rounded-lg p-4 transition-colors hover:opacity-80">
            <p class="font-semibold">Chapter 1: The Coordinate System</p>
            <p class="text-sm themed-text-muted">Sixty-one characters. Three axes. The whole framework.</p>
          </a>
        </div>
      </div>

      <!-- Go deeper -->
      <div class="mb-8">
        <h3 class="text-lg font-bold mb-4 themed-text-muted">Go deeper</h3>
        <div class="space-y-3">
          <a href="/derivation" class="block themed-surface border rounded-lg p-4 transition-colors hover:opacity-80">
            <p class="font-semibold">The Derivation</p>
            <p class="text-sm themed-text-muted">From one conditional to three dimensions.</p>
          </a>
          <a href="/convergence" class="block themed-surface border rounded-lg p-4 transition-colors hover:opacity-80">
            <p class="font-semibold">Cross-Framework Convergence</p>
            <p class="text-sm themed-text-muted">Independent frameworks pointing at the same structural facts.</p>
          </a>
          <a href="/docs/rsm/rosetta-stone" class="block themed-surface border rounded-lg p-4 transition-colors hover:opacity-80">
            <p class="font-semibold">The Rosetta Stone</p>
            <p class="text-sm themed-text-muted">The shared vocabulary between domains.</p>
          </a>
          <a href="/essay/euler-structural-grammar" class="block themed-surface border rounded-lg p-4 transition-colors hover:opacity-80">
            <p class="font-semibold">Euler's Identity as Structural Grammar</p>
            <p class="text-sm themed-text-muted">The equation as instruction manual.</p>
          </a>
        </div>
      </div>

      <!-- Question everything -->
      <div class="mb-8">
        <h3 class="text-lg font-bold mb-4 themed-text-muted">Question everything</h3>
        <div class="space-y-3">
          <a href="/essay/falsification-criteria" class="block themed-surface border rounded-lg p-4 transition-colors hover:opacity-80">
            <p class="font-semibold">Falsification Criteria</p>
            <p class="text-sm themed-text-muted">What would disprove this.</p>
          </a>
          <a href="/about/disclaimers" class="block themed-surface border rounded-lg p-4 transition-colors hover:opacity-80">
            <p class="font-semibold">Disclaimers & Honest Accounting</p>
            <p class="text-sm themed-text-muted">Who made this and how.</p>
          </a>
          <a href="/essay/steelman-audit" class="block themed-surface border rounded-lg p-4 transition-colors hover:opacity-80">
            <p class="font-semibold">The Steelman Audit</p>
            <p class="text-sm themed-text-muted">Our hardest self-critique.</p>
          </a>
        </div>
      </div>
    </section>

    <div class="themed-border border-t my-12"></div>

    <!-- The deeper archive -->
    <section class="mb-12">
      <h2 class="text-lg font-bold mb-4 themed-text-muted">The deeper archive</h2>
      <p class="themed-text-secondary text-sm mb-4">Everything is versioned. Nothing is hidden.</p>
      <div class="space-y-2 text-sm">
        <p><a href="https://github.com/goldsteinstudios/ourinfinitereality" class="hover:opacity-70" style="color: var(--color-accent);">GitHub Repository</a> — Every wrong turn, every revision.</p>
        <p><a href="/essays" class="hover:opacity-70" style="color: var(--color-accent);">Research & Essays</a> — Salvaged claims, measurement crisis chain, cross-domain validations.</p>
        <p><a href="/about" class="hover:opacity-70" style="color: var(--color-accent);">About This Project</a> — Who made it, how we made it, what you can do with it.</p>
      </div>
    </section>

    <div class="themed-border border-t my-12"></div>

    <!-- Closing -->
    <footer class="text-center themed-text-secondary mb-8">
      <p class="themed-text-muted italic">This isn't a destination. It's a workshop.</p>
    </footer>

  </div>

  <!-- Hidden modals -->

  <!-- Bundle modal -->
  <div class="contemplation-overlay" id="modal-bundle">
    <div class="contemplation-modal">
      <button class="contemplation-modal-close" aria-label="Close">&times;</button>
      <div class="themed-text-secondary leading-relaxed space-y-4">
        <p>Imagine an infinite bundle of thread with no beginning and no end. What happens when you make one cut?</p>
        <p>The threads were always there. The cut reveals them by creating space between them. The void at the cut point was always inside the bundle — you just couldn't see it.</p>
      </div>
      <div class="mt-6 text-right">
        <span class="contemplation-footnote-link" data-reveal="footnote">*</span>
      </div>
    </div>
  </div>

  <!-- Wind modal -->
  <div class="contemplation-overlay" id="modal-wind">
    <div class="contemplation-modal">
      <button class="contemplation-modal-close" aria-label="Close">&times;</button>
      <div class="themed-text-secondary leading-relaxed space-y-4">
        <p>Your friend is blowing gently into the air — just breath. You can barely hear it. Now put a flute in their path. Same breath, but suddenly there's a note — clear, specific, beautiful.</p>
        <p>The flute didn't create the wind. It shaped it. And now you can't hear the wind anymore because the note is so present it fills your attention.</p>
        <p>That's the situation this project is in. There's a structural pattern (the wind) that shows up across many frameworks (the instruments). We can't hear the wind directly — we can only hear the notes. So we listen to as many instruments as we can and notice what all the notes have in common. That common thing is what we're studying.</p>
      </div>
      <div class="mt-6 text-right">
        <span class="contemplation-footnote-link" data-reveal="footnote">*</span>
      </div>
    </div>
  </div>

  <!-- Toss modal -->
  <div class="contemplation-overlay" id="modal-toss">
    <div class="contemplation-modal">
      <button class="contemplation-modal-close" aria-label="Close">&times;</button>
      <div class="themed-text-secondary leading-relaxed space-y-4">
        <p>Farmers separate grain from chaff by throwing everything in the air and letting gravity sort. The heavy stuff falls. The light stuff drifts. You didn't judge. You created conditions for sorting to happen on its own.</p>
        <p>Try this with ideas: let everything go airborne. Notice which ones come back down with weight on their own, without you having to argue for them.</p>
      </div>
      <div class="mt-6 text-right">
        <span class="contemplation-footnote-link" data-reveal="footnote">*</span>
      </div>
    </div>
  </div>

  <!-- Footnote modal -->
  <div class="contemplation-overlay" id="modal-footnote">
    <div class="contemplation-modal">
      <button class="contemplation-modal-close" aria-label="Close">&times;</button>
      <div class="themed-text-secondary leading-relaxed">
        <p class="italic">These three exercises correspond to the first three operational positions on the oldest known copy of the Dao De Jing, carved on bamboo strips around 300 BCE.</p>
      </div>
    </div>
  </div>

</BaseLayout>

<script is:inline>
  // Open contemplation modal
  document.querySelectorAll('[data-contemplation]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var id = 'modal-' + this.getAttribute('data-contemplation');
      var overlay = document.getElementById(id);
      if (overlay) {
        overlay.classList.add('active');
        document.body.style.overflow = 'hidden';
      }
    });
  });

  // Footnote reveal: close parent modal, open footnote
  document.querySelectorAll('[data-reveal="footnote"]').forEach(function(link) {
    link.addEventListener('click', function() {
      // Close the parent overlay
      var parent = this.closest('.contemplation-overlay');
      if (parent) parent.classList.remove('active');
      // Open footnote
      var footnote = document.getElementById('modal-footnote');
      if (footnote) footnote.classList.add('active');
    });
  });

  // Close via X button
  document.querySelectorAll('.contemplation-modal-close').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var overlay = this.closest('.contemplation-overlay');
      if (overlay) {
        overlay.classList.remove('active');
        document.body.style.overflow = '';
      }
    });
  });

  // Close via background click
  document.querySelectorAll('.contemplation-overlay').forEach(function(overlay) {
    overlay.addEventListener('click', function(e) {
      if (e.target === this) {
        this.classList.remove('active');
        document.body.style.overflow = '';
      }
    });
  });

  // Close via Escape key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      document.querySelectorAll('.contemplation-overlay.active').forEach(function(overlay) {
        overlay.classList.remove('active');
      });
      document.body.style.overflow = '';
    }
  });
</script>
