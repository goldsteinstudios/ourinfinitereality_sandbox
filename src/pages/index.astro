---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ObjectCard from '../components/ObjectCard.astro';

const objects = await getCollection('objects');
const sortedObjects = objects.sort((a, b) => {
  // Sort by depth (abstract first), then alphabetically
  if (a.data.depth !== b.data.depth) return a.data.depth - b.data.depth;
  return a.data.title.localeCompare(b.data.title);
});
---

<BaseLayout title="Catalog">
  <div class="text-center mb-12">
    <h1 class="text-3xl font-bold mb-4">Our Infinite Reality</h1>
    <p class="text-[#888] max-w-xl mx-auto">
      Click any object to begin exploring. Everything connects to everything.
      You cannot arrive. You can only accumulate approaches.
    </p>
  </div>

  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-6">
    {sortedObjects.map((object) => (
      <ObjectCard object={object} />
    ))}
  </div>

  {sortedObjects.length === 0 && (
    <p class="text-center text-[#888]">No objects yet. Add MDX files to src/content/objects/</p>
  )}
</BaseLayout>
