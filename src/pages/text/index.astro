---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="The Text">
  <div class="max-w-3xl mx-auto">

    <header class="mb-12">
      <h1 class="text-3xl font-bold mb-4">The Text</h1>
      <p class="themed-text-secondary text-lg">Working with the Dao De Jing</p>
    </header>

    <section class="mb-12">
      <div class="space-y-4">
        <a href="/text/what-is-ddj" class="block themed-surface border rounded-lg p-6 transition-colors hover:opacity-80">
          <p class="font-bold text-lg mb-2">What Is the Dao De Jing?</p>
          <p class="themed-text-secondary">Background, versions, and why the archaeology matters.</p>
        </a>
        <a href="/ddj" class="block themed-surface border rounded-lg p-6 transition-colors hover:opacity-80">
          <p class="font-bold text-lg mb-2">Translated Chapters</p>
          <p class="themed-text-secondary">Character-by-character decomposition of each chapter.</p>
        </a>
        <a href="/ddj/chapter-01" class="block themed-surface border rounded-lg p-6 transition-colors hover:opacity-80">
          <p class="font-bold text-lg mb-2">Chapter 1: The Coordinate System</p>
          <p class="themed-text-secondary">The opening 61 characters. Start here.</p>
        </a>
      </div>
    </section>

    <div class="themed-border border-t my-12"></div>

    <footer class="text-center themed-text-muted">
      <p><a href="/" class="hover:opacity-70" style="color: var(--color-accent);">← Back to home</a></p>
    </footer>

  </div>
</BaseLayout>
