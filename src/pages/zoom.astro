---
import BaseLayout from '../layouts/BaseLayout.astro';

// PROTOTYPE — the premise as one clean scroll. White concentric circles on black:
// starts on the question at the top, then a gentle zoom OUT (vast) → zoom IN
// (divisible) → the words. Unlinked, /zoom.
---

<BaseLayout title="What if reality is infinite?">
  <div class="film-wrap">
    <div class="film-stage">
      <svg id="filmsvg" viewBox="-50 -50 100 100" aria-hidden="true"><g id="rings"></g></svg>

      <div class="film-cards">
        <p class="fc" data-a="-0.10" data-b="0.10">What if reality is <em>truly</em> infinite?</p>
        <p class="fc" data-a="0.14" data-b="0.35">Not just infinitely <em>vast</em>…</p>
        <p class="fc" data-a="0.39" data-b="0.60">…but also infinitely <em>divisible</em>.</p>
        <p class="fc" data-a="0.67" data-b="0.75">Zoom out forever.</p>
        <p class="fc" data-a="0.75" data-b="0.83">Zoom in forever.</p>
        <p class="fc" data-a="0.83" data-b="0.905">A reality with no center and no edge.</p>
        <p class="fc" data-a="0.905" data-b="0.972">So how could a reality like that possibly work?</p>
        <p class="fc" data-a="0.972" data-b="1.02">Let's pull a thread and find out.</p>
      </div>

      <div class="film-hint">scroll <span class="arrow">↓</span></div>
    </div>
  </div>

  <section class="entries">
    <h2 class="entries-head">Pull a thread</h2>
    <div class="entries-grid">
      <a class="entry" href="/pattern"><span class="entry-t">Follow the logic</span><span class="entry-d">How it all falls out of that one premise.</span></a>
      <a class="entry" href="/catalog"><span class="entry-t">See it in things</span><span class="entry-d">Wheels, atoms, hearts, valleys.</span></a>
      <a class="entry" href="/ddj"><span class="entry-t">The ancient version</span><span class="entry-d">The Dao De Jing, read as a coordinate system.</span></a>
      <a class="entry" href="/confidence"><span class="entry-t">How solid is it</span><span class="entry-d">The honest accounting — what's derived, what's open.</span></a>
    </div>
    <p class="entries-note">(entry points are placeholders — TBD)</p>
  </section>
</BaseLayout>

<style>
  /* Full-screen from the top: drop the site chrome and the page column for this film. */
  :global(html) { overflow-x: clip; }
  :global(header) { display: none; }
  :global(footer) { display: none; }
  :global(main) { max-width: none !important; padding: 0 !important; }

  .film-wrap {
    position: relative; height: 920vh;
    width: 100vw; margin-left: calc(50% - 50vw); background: #000;
  }
  .film-stage {
    position: sticky; top: 0; height: 100vh;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden; background: #000;
  }
  #filmsvg { width: min(88vw, 82vh); height: min(88vw, 82vh); color: #fff; display: block; }
  .film-cards { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; pointer-events: none; }
  .fc {
    position: absolute; text-align: center; opacity: 0;
    color: #fff; font-family: var(--font-body); font-weight: 700;
    font-size: clamp(1.9rem, 6vw, 3.25rem); line-height: 1.22;
    max-width: min(90vw, 34rem); padding: 0 1rem;
    text-shadow: 0 2px 28px rgba(0, 0, 0, 0.95);
  }
  .film-hint {
    position: absolute; bottom: 6%; left: 0; right: 0; text-align: center;
    color: rgba(255, 255, 255, 0.6); font-size: var(--text-sm);
    font-family: var(--font-heading); letter-spacing: var(--tracking-wide);
  }
  .arrow { display: inline-block; font-size: 1.15rem; animation: bob 1.6s ease-in-out infinite; }
  @keyframes bob { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(6px); } }
  @media (prefers-reduced-motion: reduce) { .arrow { animation: none; } }

  .entries { width: 100vw; margin-left: calc(50% - 50vw); background: #000; color: #fff; padding: 4rem 1.5rem 6rem; }
  .entries-head { text-align: center; color: #fff; font-size: var(--text-2xl); font-weight: var(--weight-bold); margin-bottom: 2.5rem; }
  .entries-grid { max-width: 40rem; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .entry { display: block; padding: 1.25rem 1.5rem; border-radius: var(--radius-lg); border: 1px solid rgba(255, 255, 255, 0.22); text-decoration: none; transition: border-color var(--transition-fast), background var(--transition-fast); }
  .entry:hover { border-color: rgba(255, 255, 255, 0.6); background: rgba(255, 255, 255, 0.04); }
  .entry-t { display: block; color: #fff; font-family: var(--font-heading); font-weight: var(--weight-semibold); margin-bottom: 0.25rem; }
  .entry-d { display: block; color: rgba(255, 255, 255, 0.6); font-size: var(--text-sm); font-family: var(--font-body); }
  .entries-note { text-align: center; color: rgba(255, 255, 255, 0.35); font-size: var(--text-sm); margin-top: 2rem; }
  @media (max-width: 520px) { .entries-grid { grid-template-columns: 1fr; } }
</style>

<script>
  const NS = 'http://www.w3.org/2000/svg';
  const N = 7;            // number of concentric circles
  const RATIO = 1.9;      // radius step between scales
  const RMAX = 150;       // largest radius (recycle happens here, off-screen and invisible)

  const box = document.getElementById('rings');
  const cards = Array.from(document.querySelectorAll('.fc'));
  const hint = document.querySelector('.film-hint');
  const wrap = document.querySelector('.film-wrap');

  const circles = [];
  for (let k = 0; k < N; k++) {
    const c = document.createElementNS(NS, 'circle');
    c.setAttribute('cx', '0'); c.setAttribute('cy', '0');
    c.setAttribute('fill', 'none'); c.setAttribute('stroke', 'currentColor');
    c.setAttribute('stroke-width', '1'); c.setAttribute('vector-effect', 'non-scaling-stroke');
    box.appendChild(c);
    circles.push({ c, k });
  }

  const clamp = (x, a, b) => Math.max(a, Math.min(b, x));
  const smooth = (a, b, x) => { const t = clamp((x - a) / (b - a), 0, 1); return t * t * (3 - 2 * t); };
  const mod = (x, m) => ((x % m) + m) % m;

  // Scroll → zoom depth. Gentle (only ±3 levels) — just enough to give the sense of zooming.
  function depthFor(p) {
    if (p < 0.14) return 0;
    if (p < 0.35) return -3 * ((p - 0.14) / 0.21);      // zoom out (vast)
    if (p < 0.39) return -3;
    if (p < 0.62) return -3 + 6 * ((p - 0.39) / 0.23);  // zoom in (divisible)
    return 3;
  }

  function render(p) {
    const cd = depthFor(p);
    const reveal = smooth(0.12, 0.17, p) * (1 - smooth(0.62, 0.67, p)); // circles only during the zoom
    for (const o of circles) {
      const L = mod(o.k - cd, N);
      const radius = RMAX * Math.pow(RATIO, -L);
      const op = smooth(0.6, 4, radius) * (1 - smooth(46, 76, radius));
      o.c.setAttribute('r', radius.toFixed(3));
      o.c.style.opacity = (op * reveal).toFixed(3);
    }
    for (const c of cards) {
      const a = parseFloat(c.dataset.a), b = parseFloat(c.dataset.b);
      c.style.opacity = (smooth(a, a + 0.05, p) * (1 - smooth(b - 0.05, b, p))).toFixed(3);
    }
    if (hint) hint.style.opacity = String(1 - smooth(0.0, 0.08, p));
  }

  let ticking = false;
  function onScroll() {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      const rect = wrap.getBoundingClientRect();
      const total = Math.max(1, wrap.offsetHeight - window.innerHeight);
      render(clamp(-rect.top / total, 0, 1));
      ticking = false;
    });
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', onScroll, { passive: true });
  render(0);
  onScroll();
</script>
