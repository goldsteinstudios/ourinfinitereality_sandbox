---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Selected Essays">
  <div class="max-w-3xl mx-auto">

    <!-- Header -->
    <header class="text-center mb-12">
      <h1 class="text-4xl font-bold mb-4">Selected Essays</h1>
      <p class="text-xl text-[#888]">Pick whatever catches your eye. You don't need to read them in order.</p>
    </header>

    <!-- Essays List -->
    <section class="mb-12 space-y-8">

      <!-- Standing Wave Pattern -->
      <a href="https://github.com/goldsteinstudios/ourinfinitereality_sandbox/blob/main/consolidated/essays/standing_wave_pattern.md" class="block bg-[#1a1a1a] border border-[#333] rounded-lg p-6 hover:border-[#555] transition-colors">
        <div class="flex justify-between items-start">
          <div>
            <h3 class="text-xl font-bold mb-2">The Standing Wave Pattern</h3>
            <p class="text-[#888] mb-2">How guitar strings, electron orbitals, and tree rings share a shape.</p>
            <p class="text-sm text-[#666]">10 min read</p>
          </div>
          <span class="text-[#888]">→</span>
        </div>
      </a>

      <!-- Euler Tao Identity -->
      <a href="/docset/current/09_euler_tao_identity.md" class="block bg-[#1a1a1a] border border-[#333] rounded-lg p-6 hover:border-[#555] transition-colors">
        <div class="flex justify-between items-start">
          <div>
            <h3 class="text-xl font-bold mb-2">Euler's Identity and the Dao</h3>
            <p class="text-[#888] mb-2">Five symbols that encode Contrast, Rotation, and Closure. The mathematical Dao De Jing.</p>
            <p class="text-sm text-[#666]">15 min read</p>
          </div>
          <span class="text-[#888]">→</span>
        </div>
      </a>

      <!-- Chapter 11 -->
      <a href="/docset/current/06_ddj_chapter11.md" class="block bg-[#1a1a1a] border border-[#333] rounded-lg p-6 hover:border-[#555] transition-colors">
        <div class="flex justify-between items-start">
          <div>
            <h3 class="text-xl font-bold mb-2">Chapter 11: The Wheel, Pot, and Room</h3>
            <p class="text-[#888] mb-2">Function lives in emptiness. The hollow makes the wheel work.</p>
            <p class="text-sm text-[#666]">12 min read</p>
          </div>
          <span class="text-[#888]">→</span>
        </div>
      </a>

      <!-- Chapter 1 -->
      <a href="/docset/current/05_ddj_chapter01.md" class="block bg-[#1a1a1a] border border-[#333] rounded-lg p-6 hover:border-[#555] transition-colors">
        <div class="flex justify-between items-start">
          <div>
            <h3 class="text-xl font-bold mb-2">Chapter 1 as Coordinate System</h3>
            <p class="text-[#888] mb-2">What if the Dao De Jing's opening isn't poetry but geometry?</p>
            <p class="text-sm text-[#666]">8 min read</p>
          </div>
          <span class="text-[#888]">→</span>
        </div>
      </a>

      <!-- Consciousness -->
      <a href="https://github.com/goldsteinstudios/ourinfinitereality_sandbox/blob/main/consolidated/essays/consciousness_great_detour.md" class="block bg-[#1a1a1a] border border-[#333] rounded-lg p-6 hover:border-[#555] transition-colors">
        <div class="flex justify-between items-start">
          <div>
            <h3 class="text-xl font-bold mb-2">Consciousness: The Great Detour</h3>
            <p class="text-[#888] mb-2">The self you can't catch looking. Consciousness as O₁ structure.</p>
            <p class="text-sm text-[#666]">20 min read</p>
          </div>
          <span class="text-[#888]">→</span>
        </div>
      </a>

      <!-- Time -->
      <a href="https://github.com/goldsteinstudios/ourinfinitereality_sandbox/blob/main/consolidated/essays/time_spiral_dance.md" class="block bg-[#1a1a1a] border border-[#333] rounded-lg p-6 hover:border-[#555] transition-colors">
        <div class="flex justify-between items-start">
          <div>
            <h3 class="text-xl font-bold mb-2">Time as Spiral Dance</h3>
            <p class="text-[#888] mb-2">Why the present is unoccupiable. Time as rotation around an unreachable now.</p>
            <p class="text-sm text-[#666]">15 min read</p>
          </div>
          <span class="text-[#888]">→</span>
        </div>
      </a>

    </section>

    <!-- More Coming -->
    <section class="mb-12 text-center">
      <p class="text-[#666] italic">More essays coming. This is alive and changing.</p>
    </section>

    <!-- Deeper Reading -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6 text-center">Want the Formal Structure?</h2>
      <div class="grid gap-4 md:grid-cols-2">
        <a href="/docset/current/01_rsm.md" class="block bg-[#1a1a1a] border border-[#333] rounded-lg p-6 hover:border-[#555] transition-colors text-center">
          <p class="font-bold mb-2">RSM v0.986</p>
          <p class="text-sm text-[#888]">The complete framework. Dense. Worth it eventually.</p>
        </a>
        <a href="/confidence" class="block bg-[#1a1a1a] border border-[#333] rounded-lg p-6 hover:border-[#555] transition-colors text-center">
          <p class="font-bold mb-2">How Solid Is This?</p>
          <p class="text-sm text-[#888]">Our confidence map. What we know vs. what we're guessing.</p>
        </a>
      </div>
    </section>

    <!-- Footer -->
    <footer class="text-center text-[#666] text-sm border-t border-[#333] pt-8">
      <p class="italic">Pattern, not proof.</p>
      <p class="mt-2">Will Goldstein & Claude — December 2025</p>
    </footer>

  </div>
</BaseLayout>
