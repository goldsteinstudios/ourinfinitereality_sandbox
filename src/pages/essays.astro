---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allEssays = await getCollection('essays');
const essays = allEssays.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Selected Essays">
  <div class="max-w-3xl mx-auto">

    <!-- Header -->
    <header class="text-center mb-12">
      <h1 class="text-4xl font-bold mb-4">Selected Essays</h1>
      <p class="text-xl themed-text-muted">Pick whatever catches your eye. You don't need to read them in order.</p>
    </header>

    <!-- Essays List -->
    <section class="mb-12 space-y-6">
      {essays.map((essay) => (
        <a href={`/essay/${essay.slug}`} class="block themed-surface border rounded-lg p-6 transition-colors">
          <div class="flex justify-between items-start">
            <div>
              <h3 class="text-xl font-bold mb-2">{essay.data.title}</h3>
              <p class="themed-text-muted mb-2">{essay.data.description}</p>
              <p class="text-sm themed-text-muted">{essay.data.readTime} read</p>
            </div>
            <span class="themed-text-muted">→</span>
          </div>
        </a>
      ))}
    </section>

    <!-- More Coming -->
    <section class="mb-12 text-center">
      <p class="themed-text-muted italic">More essays coming. This is alive and changing.</p>
    </section>

    <!-- Deeper Reading -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6 text-center">Want the Formal Structure?</h2>
      <div class="grid gap-4 md:grid-cols-2">
        <a href="/docset/rsm_complete.html" class="block themed-surface border rounded-lg p-6 transition-colors text-center">
          <p class="font-bold mb-2">RSM v0.987</p>
          <p class="text-sm themed-text-muted">The complete framework. Dense. Worth it eventually.</p>
        </a>
        <a href="/confidence" class="block themed-surface border rounded-lg p-6 transition-colors text-center">
          <p class="font-bold mb-2">How Solid Is This?</p>
          <p class="text-sm themed-text-muted">Our confidence map. What we know vs. what we're guessing.</p>
        </a>
      </div>
    </section>

    <!-- Footer -->
    <footer class="text-center themed-text-muted text-sm themed-border border-t pt-8">
      <p class="italic">Pattern, not proof.</p>
      <p class="mt-2">Will Goldstein & Claude — December 2025</p>
    </footer>

  </div>
</BaseLayout>
