---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allTranslations = await getCollection('translations');
const translations = allTranslations.sort((a, b) => a.data.chapter - b.data.chapter);
---

<BaseLayout title="Dao De Jing — Structural Translation">
  <div class="max-w-3xl mx-auto">

    <!-- Header -->
    <header class="text-center mb-12">
      <h1 class="text-4xl font-bold mb-4">道德經</h1>
      <p class="text-xl themed-text-muted mb-2">Structural Translation</p>
      <p class="themed-text-muted">Reading the DDJ as the subject of a structural translation, not as mystical poetry.</p>
    </header>

    <!-- Version Note -->
    <section class="mb-8 themed-surface border rounded-lg p-4 text-sm">
      <p class="themed-text-muted">
        <strong>Living document.</strong> Each chapter shows its translation version and changelog.
        These translations evolve as understanding deepens.
      </p>
    </section>

    <!-- Chapters List -->
    <section class="mb-12">
      <div class="grid gap-3">
        {translations.map((t) => (
          <a href={`/ddj/${t.slug}`} class="block themed-surface border rounded-lg p-4 transition-colors hover:border-[var(--color-accent)]">
            <div class="flex justify-between items-center">
              <div class="flex items-baseline gap-3">
                <span class="text-2xl font-bold themed-text-muted">{t.data.chapter}</span>
                <div>
                  <span class="font-medium">{t.data.chineseTitle}</span>
                  <span class="themed-text-muted mx-2">—</span>
                  <span class="themed-text-secondary">{t.data.englishTitle}</span>
                </div>
              </div>
              <div class="text-sm themed-text-muted">
                v{t.data.version}
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Progress Note -->
    <section class="mb-12 text-center">
      <p class="themed-text-muted">
        {translations.length} of 81 chapters translated.
      </p>
    </section>

    <!-- Links -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6 text-center">Related</h2>
      <div class="grid gap-4 md:grid-cols-3">
        <a href="/guodian" class="block themed-surface border rounded-lg p-6 transition-colors text-center">
          <p class="font-bold mb-2">郭店老子甲</p>
          <p class="text-sm themed-text-muted">Interactive Guodian Bundle A (~300 BCE).</p>
        </a>
        <a href="/essays" class="block themed-surface border rounded-lg p-6 transition-colors text-center">
          <p class="font-bold mb-2">Essays</p>
          <p class="text-sm themed-text-muted">Commentary and analysis of specific chapters.</p>
        </a>
      </div>
    </section>

    <!-- Footer -->
    <footer class="text-center themed-text-muted text-sm themed-border border-t pt-8">
      <p class="italic">The translation begins in the characters.</p>
      <p class="mt-2">Will Goldstein — December 2025</p>
    </footer>

  </div>
</BaseLayout>
