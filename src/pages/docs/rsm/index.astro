---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout title="RSM Documentation">
  <div class="max-w-3xl mx-auto">

    <header class="mb-12">
      <h1 class="text-3xl font-bold mb-4">RSM Documentation</h1>
      <p class="themed-text-secondary text-lg">The Recursive Structural Model</p>
    </header>

    <section class="mb-12">
      <div class="space-y-4">
        <a href="/docs/rsm/rosetta-stone" class="block themed-surface border rounded-lg p-6 transition-colors hover:opacity-80">
          <p class="font-bold text-lg mb-2">The Rosetta Stone</p>
          <p class="themed-text-secondary">The shared vocabulary for translating between domains. Start here.</p>
        </a>
        <a href="/docset/rsm_complete.html" class="block themed-surface border rounded-lg p-6 transition-colors hover:opacity-80">
          <p class="font-bold text-lg mb-2">RSM v0.995 Complete</p>
          <p class="themed-text-secondary">The full technical specification in one document.</p>
        </a>
      </div>
    </section>

    <div class="themed-border border-t my-12"></div>

    <footer class="text-center themed-text-muted">
      <p><a href="/" class="hover:opacity-70" style="color: var(--color-accent);">← Back to home</a></p>
    </footer>

  </div>
</BaseLayout>
