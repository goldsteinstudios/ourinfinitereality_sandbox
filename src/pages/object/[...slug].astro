---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NavigationPanel from '../../components/NavigationPanel.astro';

export async function getStaticPaths() {
  const objects = await getCollection('objects');
  return objects.map((object) => ({
    params: { slug: object.slug },
    props: { object },
  }));
}

interface Props {
  object: CollectionEntry<'objects'>;
}

const { object } = Astro.props;
const { Content } = await object.render();
const { title, subtitle, source, domain, icon, deeper, lateral, surface } = object.data;

// Get all objects to filter navigation links
const allObjects = await getCollection('objects');
const existingIds = new Set(allObjects.map(o => o.data.id));

// Filter to only show links that exist
const filteredDeeper = deeper.filter(id => existingIds.has(id));
const filteredLateral = lateral.filter(id => existingIds.has(id));
const filteredSurface = surface.filter(id => existingIds.has(id));

// Get the actual object data for each link
const deeperObjects = allObjects.filter(o => filteredDeeper.includes(o.data.id));
const lateralObjects = allObjects.filter(o => filteredLateral.includes(o.data.id));
const surfaceObjects = allObjects.filter(o => filteredSurface.includes(o.data.id));
---

<BaseLayout title={title}>
  <article class="max-w-2xl mx-auto">
    <!-- Header -->
    <header class="text-center mb-12">
      <div class="w-24 h-24 mx-auto mb-6 flex items-center justify-center text-6xl">
        {icon ? (
          <img src={icon} alt="" class="w-full h-full" />
        ) : (
          <span class="opacity-50">○</span>
        )}
      </div>
      <h1 class="text-4xl font-bold mb-2">{title}</h1>
      {subtitle && <p class="text-xl text-[#888]">{subtitle}</p>}
      <div class="flex items-center justify-center gap-4 mt-4 text-sm text-[#666]">
        {source && <span>{source}</span>}
        <span class="uppercase tracking-wide">{domain}</span>
      </div>
    </header>

    <!-- Essay Content -->
    <div class="prose prose-invert prose-lg max-w-none">
      <Content />
    </div>

    <!-- Navigation Panel -->
    <NavigationPanel
      deeper={deeperObjects}
      lateral={lateralObjects}
      surface={surfaceObjects}
    />

    <!-- Back Link -->
    <div class="text-center mt-12">
      <a href="/catalog" class="text-[#888] hover:text-white transition-colors">
        ← Back to Objects
      </a>
    </div>
  </article>
</BaseLayout>

<style>
  .prose h2 {
    @apply text-2xl font-bold mt-12 mb-4 text-purple-400;
  }
  .prose h3 {
    @apply text-xl font-bold mt-8 mb-3 text-white;
  }
  .prose p {
    @apply mb-4 leading-relaxed text-[#ccc];
  }
  .prose strong {
    @apply text-white font-semibold;
  }
  .prose em {
    @apply text-[#aaa] italic;
  }
  .prose blockquote {
    @apply border-l-4 border-purple-500/50 pl-4 italic text-[#888] my-6;
  }
  .prose ul, .prose ol {
    @apply mb-4 ml-6 text-[#ccc];
  }
  .prose li {
    @apply mb-2;
  }
  .prose a {
    @apply text-purple-400 hover:text-purple-300 transition-colors;
  }
  .prose table {
    @apply w-full my-6;
  }
  .prose th {
    @apply text-left pb-2 border-b border-[#333] text-[#888];
  }
  .prose td {
    @apply py-2 border-b border-[#222] text-[#ccc];
  }
</style>
