---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NavigationPanel from '../../components/NavigationPanel.astro';

export async function getStaticPaths() {
  const objects = await getCollection('objects');
  return objects.map((object) => ({
    params: { slug: object.slug },
    props: { object },
  }));
}

interface Props {
  object: CollectionEntry<'objects'>;
}

const { object } = Astro.props;
const { Content } = await object.render();
const { title, subtitle, source, domain, icon, deeper, lateral, surface } = object.data;

// Get all objects to filter navigation links
const allObjects = await getCollection('objects');
const existingIds = new Set(allObjects.map(o => o.data.id));

// Filter to only show links that exist
const filteredDeeper = deeper.filter(id => existingIds.has(id));
const filteredLateral = lateral.filter(id => existingIds.has(id));
const filteredSurface = surface.filter(id => existingIds.has(id));

// Get the actual object data for each link
const deeperObjects = allObjects.filter(o => filteredDeeper.includes(o.data.id));
const lateralObjects = allObjects.filter(o => filteredLateral.includes(o.data.id));
const surfaceObjects = allObjects.filter(o => filteredSurface.includes(o.data.id));
---

<BaseLayout title={title}>
  <article class="max-w-2xl mx-auto">
    <!-- Header -->
    <header class="text-center mb-12">
      <div class="w-24 h-24 mx-auto mb-6 flex items-center justify-center text-6xl">
        {icon ? (
          <img src={icon} alt="" class="w-full h-full" />
        ) : (
          <span class="opacity-50">○</span>
        )}
      </div>
      <h1 class="text-4xl font-bold mb-2">{title}</h1>
      {subtitle && <p class="text-xl themed-text-muted">{subtitle}</p>}
      <div class="flex items-center justify-center gap-4 mt-4 text-sm themed-text-muted">
        {source && <span>{source}</span>}
        <span class="uppercase tracking-wide">{domain}</span>
      </div>
    </header>

    <!-- Essay Content -->
    <div class="prose prose-themed prose-lg max-w-none">
      <Content />
    </div>

    <!-- Navigation Panel -->
    <NavigationPanel
      deeper={deeperObjects}
      lateral={lateralObjects}
      surface={surfaceObjects}
    />

    <!-- Back Link -->
    <div class="text-center mt-12">
      <a href="/catalog" class="themed-text-muted hover:opacity-80 transition-opacity">
        ← Back to Objects
      </a>
    </div>
  </article>
</BaseLayout>

<style>
  .prose h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 3rem;
    margin-bottom: 1rem;
    color: var(--color-accent);
  }
  .prose h3 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }
  .prose h4 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }
  .prose p {
    margin-bottom: 1rem;
    line-height: 1.8;
    color: var(--color-text-secondary);
  }
  .prose strong {
    font-weight: 700;
    color: var(--color-text);
  }
  .prose em {
    font-style: italic;
  }
  .prose blockquote {
    border-left: 4px solid var(--color-accent);
    padding-left: 1.5rem;
    margin: 1.5rem 0;
    color: var(--color-text-secondary);
  }
  .prose blockquote p {
    color: var(--color-text-secondary);
  }
  .prose ul {
    list-style-type: disc;
    margin-bottom: 1.5rem;
    margin-left: 1.5rem;
    padding-left: 0.5rem;
    color: var(--color-text-secondary);
  }
  .prose ol {
    list-style-type: decimal;
    margin-bottom: 1.5rem;
    margin-left: 1.5rem;
    padding-left: 0.5rem;
    color: var(--color-text-secondary);
  }
  .prose li {
    margin-bottom: 0.5rem;
    padding-left: 0.25rem;
  }
  .prose li::marker {
    color: var(--color-text-muted);
  }
  .prose a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose a:hover {
    opacity: 0.8;
  }
  .prose table {
    width: 100%;
    margin: 1.5rem 0;
    border-collapse: collapse;
    font-size: 0.95rem;
  }
  .prose th {
    text-align: left;
    padding: 0.75rem 1rem;
    border-bottom: 2px solid var(--color-border);
    color: var(--color-text);
    font-weight: 600;
    background: var(--color-surface);
  }
  .prose td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-border-light);
    color: var(--color-text-secondary);
    vertical-align: top;
  }
  .prose tr:hover td {
    background: var(--color-surface);
  }
  .prose code {
    background: var(--color-surface);
    padding: 0.2rem 0.5rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
    border: 1px solid var(--color-border-light);
  }
  .prose pre {
    background: var(--color-surface);
    padding: 1.25rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin: 1.5rem 0;
    border: 1px solid var(--color-border);
    font-size: 0.9rem;
    line-height: 1.6;
  }
  .prose pre code {
    background: transparent;
    padding: 0;
    border: none;
    font-size: inherit;
  }
  .prose hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0;
  }
</style>
