---
import type { CollectionEntry } from 'astro:content';

interface Props {
  deeper: CollectionEntry<'objects'>[];
  lateral: CollectionEntry<'objects'>[];
  surface: CollectionEntry<'objects'>[];
}

const { deeper, lateral, surface } = Astro.props;

const hasAnyLinks = deeper.length > 0 || lateral.length > 0 || surface.length > 0;
---

{hasAnyLinks && (
  <nav class="mt-16 pt-8 border-t border-[#2a2a2a]">
    <h2 class="text-xl font-semibold mb-6 text-center">Where to Go From Here</h2>

    <div class="grid md:grid-cols-3 gap-8">
      <!-- Deeper -->
      {deeper.length > 0 && (
        <div>
          <h3 class="flex items-center gap-2 text-blue-400 font-semibold mb-4">
            <span class="text-lg">↓</span>
            Go Deeper
          </h3>
          <p class="text-xs text-[#666] mb-3">Into components</p>
          <ul class="space-y-2">
            {deeper.map((obj) => (
              <li>
                <a
                  href={`/object/${obj.slug}`}
                  class="block p-3 rounded bg-[#1a1a1a] hover:bg-[#222] border border-blue-500/20 hover:border-blue-500/50 transition-all"
                >
                  <span class="font-medium">{obj.data.title}</span>
                  {obj.data.subtitle && (
                    <span class="block text-sm text-[#888] mt-1">{obj.data.subtitle}</span>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Lateral -->
      {lateral.length > 0 && (
        <div>
          <h3 class="flex items-center gap-2 text-green-400 font-semibold mb-4">
            <span class="text-lg">↔</span>
            Explore Parallels
          </h3>
          <p class="text-xs text-[#666] mb-3">Same-level patterns</p>
          <ul class="space-y-2">
            {lateral.map((obj) => (
              <li>
                <a
                  href={`/object/${obj.slug}`}
                  class="block p-3 rounded bg-[#1a1a1a] hover:bg-[#222] border border-green-500/20 hover:border-green-500/50 transition-all"
                >
                  <span class="font-medium">{obj.data.title}</span>
                  {obj.data.subtitle && (
                    <span class="block text-sm text-[#888] mt-1">{obj.data.subtitle}</span>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Surface -->
      {surface.length > 0 && (
        <div>
          <h3 class="flex items-center gap-2 text-amber-400 font-semibold mb-4">
            <span class="text-lg">↑</span>
            Rise to Pattern
          </h3>
          <p class="text-xs text-[#666] mb-3">Toward abstraction</p>
          <ul class="space-y-2">
            {surface.map((obj) => (
              <li>
                <a
                  href={`/object/${obj.slug}`}
                  class="block p-3 rounded bg-[#1a1a1a] hover:bg-[#222] border border-amber-500/20 hover:border-amber-500/50 transition-all"
                >
                  <span class="font-medium">{obj.data.title}</span>
                  {obj.data.subtitle && (
                    <span class="block text-sm text-[#888] mt-1">{obj.data.subtitle}</span>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </nav>
)}
