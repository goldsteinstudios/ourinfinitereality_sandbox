---
// Beat: distinction obtains. A circle in the left half traces itself; the instant it
// closes it floods to a solid disc with THIS knocked out of the fill, and NOT/THIS
// appears simultaneously at the mirror position on the right. Draw + snap only, no fade.
// One currentColor + an SVG knockout, so it inverts automatically between themes.
interface Props { class?: string; }
const { class: className } = Astro.props;
---
<svg viewBox="0 0 100 100" class:list={['oir-diagram cut', className]} role="img"
  aria-label="A circle on the left draws itself then floods solid with THIS inside; NOT THIS answers from the mirror position on the right.">
  <style>
    .cut { width: 100%; height: auto; display: block; color: var(--color-text); }
    .cut .gc-out {
      fill: none; stroke: currentColor; stroke-width: 1.6;
      stroke-dasharray: 100; stroke-dashoffset: 100;
      transform: rotate(-90deg); transform-origin: 26px 50px;
    }
    .cut .gc-fill { fill: currentColor; opacity: 0; }
    .cut .gc-notthis {
      fill: currentColor; text-anchor: start; dominant-baseline: central; opacity: 0;
      font-family: var(--font-heading); font-weight: 700; font-size: 10px; letter-spacing: 0.06em;
    }
    .cut .knock {
      text-anchor: middle; dominant-baseline: central;
      font-family: var(--font-heading); font-weight: 700; font-size: 11px; letter-spacing: 0.04em;
    }

    /* line traces first; the instant it closes (0.9s) the fill + both labels snap on together */
    .cut.go .gc-out,     .cut:hover .gc-out     { animation: cut-draw 0.9s ease forwards; }
    .cut.go .gc-fill,    .cut:hover .gc-fill    { animation: cut-snap 0.01s linear 0.9s forwards; }
    .cut.go .gc-notthis, .cut:hover .gc-notthis { animation: cut-snap 0.01s linear 0.9s forwards; }
    @keyframes cut-draw { to { stroke-dashoffset: 0; } }
    @keyframes cut-snap { to { opacity: 1; } }

    /* no-JS / reduced-motion: show the settled end state (observer never adds .go here) */
    @media (prefers-reduced-motion: reduce) {
      .cut .gc-out { stroke-dashoffset: 0; }
      .cut .gc-fill, .cut .gc-notthis { opacity: 1; }
    }
  </style>

  <defs>
    <mask id="cut-knock" maskUnits="userSpaceOnUse">
      <rect x="0" y="0" width="100" height="100" fill="#fff"></rect>
      <text class="knock" x="26" y="49" fill="#000">THIS</text>
    </mask>
  </defs>

  <circle class="gc-out" cx="26" cy="50" r="18" pathLength="100"></circle>
  <circle class="gc-fill" cx="26" cy="50" r="18" mask="url(#cut-knock)"></circle>
  <text class="gc-notthis"><tspan x="56" y="45">NOT</tspan><tspan x="56" y="56">THIS</tspan></text>
</svg>
