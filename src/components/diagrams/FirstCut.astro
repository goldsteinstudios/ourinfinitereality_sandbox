---
// Beat: distinction obtains. A field split by a single cut that draws itself;
// the two sides settle to different tints (this / not-this). Draw + opacity only.
interface Props { class?: string; }
const { class: className } = Astro.props;
---
<svg viewBox="0 0 100 100" class:list={['oir-diagram cut', className]} role="img"
  aria-label="A field divided by a single cut into two sides, each defined by the other.">
  <style>
    .cut { width: 100%; height: auto; display: block; color: var(--color-accent); }
    .cut .field { fill: none; stroke: currentColor; stroke-width: 1; }
    .cut .half { fill: currentColor; opacity: 0; }
    .cut .line { stroke: currentColor; stroke-width: 1.8; stroke-dasharray: 72; stroke-dashoffset: 72; }
    .cut.go .line, .cut:hover .line { animation: cut-draw 0.9s ease forwards; }
    .cut.go .halfL, .cut:hover .halfL { animation: cut-l 0.7s ease 0.8s forwards; }
    .cut.go .halfR, .cut:hover .halfR { animation: cut-r 0.7s ease 0.8s forwards; }
    @keyframes cut-draw { to { stroke-dashoffset: 0; } }
    @keyframes cut-l { to { opacity: 0.13; } }
    @keyframes cut-r { to { opacity: 0.05; } }
  </style>
  <circle class="field" cx="50" cy="50" r="34"></circle>
  <path class="half halfL" d="M50 16 A34 34 0 0 0 50 84 Z"></path>
  <path class="half halfR" d="M50 16 A34 34 0 0 1 50 84 Z"></path>
  <line class="line" x1="50" y1="16" x2="50" y2="84"></line>
</svg>
