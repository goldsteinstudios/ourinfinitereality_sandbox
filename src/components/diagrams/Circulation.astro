---
// Beat: circulation. A point orbits the hollow center once — the only way to
// persist around a center you can't reach or cross. Rotate only (viewBox-safe).
interface Props { class?: string; }
const { class: className } = Astro.props;
---
<svg viewBox="0 0 100 100" class:list={['oir-diagram circ', className]} role="img"
  aria-label="A point orbiting a hollow center it never reaches.">
  <style>
    .circ { width: 100%; height: auto; display: block; color: var(--color-accent); }
    .circ .orbit { fill: none; stroke: currentColor; stroke-width: 1; opacity: 0.4; stroke-dasharray: 2 3; }
    .circ .center { fill: none; stroke: currentColor; stroke-width: 1.2; }
    .circ .dot { fill: currentColor; }
    .circ .spin { transform-origin: 50px 50px; }
    .circ.go .spin, .circ:hover .spin { animation: circ-spin 3s cubic-bezier(0.35, 0, 0.35, 1); }
    @keyframes circ-spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  </style>
  <circle class="orbit" cx="50" cy="50" r="34"></circle>
  <circle class="center" cx="50" cy="50" r="4"></circle>
  <g class="spin"><circle class="dot" cx="50" cy="16" r="3"></circle></g>
</svg>
