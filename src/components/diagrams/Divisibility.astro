---
// Beat: infinite divisibility — a line that keeps subdividing, no smallest rung.
// Tick generations fade/grow in, staggered. Safe transforms only (scaleY/opacity).
interface Props { class?: string; }
const { class: className } = Astro.props;
---
<svg viewBox="0 0 100 42" class:list={['oir-diagram divi', className]} role="img"
  aria-label="A line subdividing again and again, without a smallest step.">
  <style>
    .divi { width: 100%; height: auto; display: block; color: var(--color-accent); }
    .divi line { stroke: currentColor; }
    .divi .base { stroke-width: 1.2; }
    .divi .g { opacity: 0; transform: scaleY(0.15); transform-origin: 50% 20px; }
    .divi.go .g, .divi:hover .g { animation: divi-in 0.5s ease forwards; }
    .divi.go .g2, .divi:hover .g2 { animation-delay: 0.35s; }
    .divi.go .g3, .divi:hover .g3 { animation-delay: 0.7s; }
    .divi.go .g4, .divi:hover .g4 { animation-delay: 1.05s; }
    @keyframes divi-in { to { opacity: 1; transform: scaleY(1); } }
  </style>
  <line class="base" x1="6" y1="20" x2="94" y2="20"></line>
  <g style="opacity:1;transform:none">
    <line x1="6" y1="9" x2="6" y2="31" stroke-width="1.5"></line>
    <line x1="94" y1="9" x2="94" y2="31" stroke-width="1.5"></line>
  </g>
  <g class="g g2"><line x1="50" y1="11" x2="50" y2="29" stroke-width="1.2" opacity="0.9"></line></g>
  <g class="g g3">
    <line x1="28" y1="13" x2="28" y2="27" opacity="0.7"></line>
    <line x1="72" y1="13" x2="72" y2="27" opacity="0.7"></line>
  </g>
  <g class="g g4">
    <line x1="17" y1="15" x2="17" y2="25" opacity="0.5"></line>
    <line x1="39" y1="15" x2="39" y2="25" opacity="0.5"></line>
    <line x1="61" y1="15" x2="61" y2="25" opacity="0.5"></line>
    <line x1="83" y1="15" x2="83" y2="25" opacity="0.5"></line>
  </g>
</svg>
