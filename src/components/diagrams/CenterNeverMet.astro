---
// Beat: the center is never met. Converging rings crowd toward a hollow center;
// a point approaches along a radius and diminishes toward a limit it never reaches.
// CSS scale (viewBox-safe). Shared .oir-diagram observer toggles .go on scroll-in.
interface Props { class?: string; }
const { class: className } = Astro.props;
---
<svg viewBox="0 0 100 100" class:list={['oir-diagram cnm', className]} role="img"
  aria-label="Concentric rings crowd toward a hollow center; a point approaches along a radius and never arrives.">
  <style>
    .cnm { width: 100%; height: auto; display: block; color: var(--color-accent); }
    .cnm .ring { fill: none; stroke: currentColor; stroke-width: 1; }
    .cnm .center { fill: none; stroke: currentColor; stroke-width: 1.2; }
    .cnm .traveler { fill: currentColor; }
    .cnm .radius { stroke: currentColor; stroke-width: 0.5; opacity: 0.2; }
    .cnm .mover { transform: scale(1); transform-origin: 50px 50px; }
    .cnm.go .mover, .cnm:hover .mover { animation: cnm-approach 2.8s cubic-bezier(0.16, 0.78, 0.1, 1) forwards; }
    @keyframes cnm-approach { from { transform: scale(1); } to { transform: scale(0.12); } }
  </style>
  <circle class="ring" cx="50" cy="50" r="46" opacity="0.3"></circle>
  <circle class="ring" cx="50" cy="50" r="32" opacity="0.4"></circle>
  <circle class="ring" cx="50" cy="50" r="22" opacity="0.5"></circle>
  <circle class="ring" cx="50" cy="50" r="15" opacity="0.6"></circle>
  <circle class="ring" cx="50" cy="50" r="9.5" opacity="0.72"></circle>
  <circle class="ring" cx="50" cy="50" r="5.5" opacity="0.85"></circle>
  <circle class="ring" cx="50" cy="50" r="3"></circle>
  <circle class="center" cx="50" cy="50" r="1.4"></circle>
  <line class="radius" x1="50" y1="50" x2="96" y2="50"></line>
  <g class="mover"><circle class="traveler" cx="96" cy="50" r="2.6"></circle></g>
</svg>
