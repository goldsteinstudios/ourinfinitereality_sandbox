---
// Diagram: "the center is never met" — converging rings crowd toward a hollow
// center; a point approaches along a radius and diminishes toward a limit it
// never reaches. Line-art, currentColor, in the object-glyph idiom. Geometry is
// the asymptotic approach (origin.svg validates the concentric-rings picture);
// animation uses CSS scale (viewBox-safe, same technique as the glyphs).
interface Props {
  size?: string;
  caption?: string;
  class?: string;
}
const {
  size = '240px',
  caption = 'The center is approached, never reached.',
  class: className,
} = Astro.props;
---

<figure class:list={['cnm-figure', 'mx-auto', className]} style={`max-width:${size};`}>
  <svg viewBox="0 0 100 100" class="cnm" role="img"
    aria-label="Concentric rings crowd toward a hollow center; a point approaches along a radius and never arrives.">
    <style>
      .cnm { width: 100%; height: auto; display: block; color: var(--color-accent); }
      .cnm .ring { fill: none; stroke: currentColor; stroke-width: 1; }
      .cnm .center { fill: none; stroke: currentColor; stroke-width: 1.2; }
      .cnm .traveler { fill: currentColor; }
      .cnm .radius { stroke: currentColor; stroke-width: 0.5; opacity: 0.2; }
      .cnm .mover { transform: scale(1); transform-origin: 50px 50px; }
      .cnm.go .mover, .cnm:hover .mover {
        animation: cnm-approach 2.8s cubic-bezier(0.16, 0.78, 0.1, 1) forwards;
      }
      @keyframes cnm-approach { from { transform: scale(1); } to { transform: scale(0.12); } }
      @media (prefers-reduced-motion: reduce) {
        .cnm .mover { transform: scale(0.4); }
        .cnm.go .mover, .cnm:hover .mover { animation: none; }
      }
    </style>
    <circle class="ring" cx="50" cy="50" r="46" opacity="0.3"></circle>
    <circle class="ring" cx="50" cy="50" r="32" opacity="0.4"></circle>
    <circle class="ring" cx="50" cy="50" r="22" opacity="0.5"></circle>
    <circle class="ring" cx="50" cy="50" r="15" opacity="0.6"></circle>
    <circle class="ring" cx="50" cy="50" r="9.5" opacity="0.72"></circle>
    <circle class="ring" cx="50" cy="50" r="5.5" opacity="0.85"></circle>
    <circle class="ring" cx="50" cy="50" r="3"></circle>
    <circle class="center" cx="50" cy="50" r="1.4"></circle>
    <line class="radius" x1="50" y1="50" x2="96" y2="50"></line>
    <g class="mover"><circle class="traveler" cx="96" cy="50" r="2.6"></circle></g>
  </svg>
  {caption && <figcaption class="text-sm themed-text-muted italic text-center mt-3">{caption}</figcaption>}
</figure>

<script>
  // Play once when the figure scrolls into view (no removal — it rests near the
  // center, having never arrived). Respects prefers-reduced-motion.
  const rm = window.matchMedia('(prefers-reduced-motion: reduce)');
  if (!rm.matches && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) { e.target.classList.add('go'); io.unobserve(e.target); }
        }
      },
      { threshold: 0.5 }
    );
    document.querySelectorAll('svg.cnm').forEach((el) => io.observe(el));
  }
</script>
