---
// Beat: a cut brings a world. FIRST PASS — GEOMETRY FOR WILL TO RULE.
// Two axes (the modes) crossing at the origin O; the conserved-product gradient G
// as a hyperbola asymptotic to both axes; the balance line B (equal magnitudes);
// the realized crossing P where G meets B. This encodes real structure (checks.py
// territory) — the shapes/labels are a draft, not a ruled claim.
interface Props { class?: string; }
const { class: className } = Astro.props;
---
<svg viewBox="0 0 100 100" class:list={['oir-diagram cbw', className]} role="img"
  aria-label="Two axes crossing at a center, a curved gradient between the poles, a balance line, and the point where they meet.">
  <style>
    .cbw { width: 100%; height: auto; display: block; color: var(--color-accent); }
    .cbw line, .cbw path { fill: none; stroke: currentColor; }
    .cbw .axis { stroke-width: 1.2; }
    .cbw .grad { stroke-width: 1.6; stroke-dasharray: 120; stroke-dashoffset: 120; }
    .cbw .bal { stroke-width: 1; opacity: 0.5; stroke-dasharray: 3 3; }
    .cbw .o { fill: none; stroke: currentColor; stroke-width: 1.2; }
    .cbw .p { fill: currentColor; opacity: 0; }
    .cbw .lbl { font-size: 6px; fill: currentColor; opacity: 0.6; font-family: var(--font-heading); }
    .cbw.go .grad, .cbw:hover .grad { animation: cbw-draw 1.1s ease 0.2s forwards; }
    .cbw.go .p, .cbw:hover .p { animation: cbw-p 0.5s ease 1.2s forwards; }
    @keyframes cbw-draw { to { stroke-dashoffset: 0; } }
    @keyframes cbw-p { to { opacity: 1; } }
  </style>
  <!-- axes: the two modes, crossing at O (never reaching absolute — extend to edges) -->
  <line class="axis" x1="50" y1="8" x2="50" y2="92"></line>
  <line class="axis" x1="8" y1="50" x2="92" y2="50"></line>
  <!-- balance B: equal magnitudes (the 45-degree line through O) -->
  <line class="bal" x1="20" y1="80" x2="80" y2="20"></line>
  <!-- gradient G: conserved product, asymptotic to both axes (upper-right quadrant) -->
  <path class="grad" d="M 56 14 C 60 40, 62 42, 86 44"></path>
  <!-- O: the unmet crossing (origin) -->
  <circle class="o" cx="50" cy="50" r="2"></circle>
  <!-- P: the realized crossing, where G meets B -->
  <circle class="p" cx="65.5" cy="34.5" r="2.6"></circle>
  <text class="lbl" x="53" y="58">O</text>
  <text class="lbl" x="69" y="33">P</text>
</svg>
