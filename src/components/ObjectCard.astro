---
import type { CollectionEntry } from 'astro:content';
import Icon from './Icon.astro';
import { ICON_NAMES, type IconName } from './icon-names';

interface Props {
  object: CollectionEntry<'objects'>;
}

const { object } = Astro.props;
const { title, subtitle, domain, icon } = object.data;

const domainColors: Record<string, string> = {
  ddj: 'border-amber-500/30 hover:border-amber-500',
  biology: 'border-green-500/30 hover:border-green-500',
  physics: 'border-blue-500/30 hover:border-blue-500',
  pattern: 'border-purple-500/30 hover:border-purple-500',
};

// icon is stored as a path (e.g. "/icons/wheel.svg"); Icon takes the bare name.
const iconName = icon?.replace(/^.*\//, '').replace(/\.svg$/, '');
const hasIcon = !!iconName && (ICON_NAMES as readonly string[]).includes(iconName);
---

<a
  href={`/object/${object.slug}`}
  class={`block p-6 rounded-lg border-2 themed-surface transition-all ${domainColors[domain] || 'border-gray-500/30'}`}
>
  <div class="w-16 h-16 mx-auto mb-4 flex items-center justify-center text-4xl">
    {hasIcon ? (
      <Icon name={iconName as IconName} size="100%" />
    ) : (
      <span class="opacity-50">○</span>
    )}
  </div>
  <h3 class="text-center font-semibold">{title}</h3>
  {subtitle && <p class="text-center text-sm themed-text-muted mt-1">{subtitle}</p>}
  <p class="text-center text-xs themed-text-muted mt-2 uppercase tracking-wide">{domain}</p>
</a>
